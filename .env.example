# PhishScope Environment Configuration

# ============================================
# LLM Provider Configuration
# ============================================
# Choose your LLM provider: 'watsonx', 'rits', 'openai', or 'ollama'
LLM_PROVIDER=watsonx

# Optional: Override the model (if not set, uses provider default)
LLM_MODEL=

# ============================================
# IBM watsonx.ai Configuration
# ============================================
# Get your credentials from: https://cloud.ibm.com/

# Required: Your IBM Cloud API Key
WATSONX_API_KEY=your_watsonx_api_key_here

# Required: Your watsonx.ai Project ID
WATSONX_PROJECT_ID=your_project_id_here

# Optional: watsonx.ai Service URL (default: us-south)
WATSONX_API_ENDPOINT=https://us-south.ml.cloud.ibm.com

# Optional: LLM Model ID (default: ibm/granite-3-8b-instruct)
# Available models:
# - ibm/granite-3-8b-instruct (default, good for security analysis)
# - ibm/granite-4-h-small (newer, more capable)
# - meta-llama/llama-3-3-70b-instruct (larger, more powerful)
WATSONX_MODEL_ID=ibm/granite-3-8b-instruct

# ============================================
# RITS OpenAI-Compatible API Configuration
# ============================================
# For RITS provider, set LLM_PROVIDER=rits above

# Required: Your RITS API Key
RITS_API_KEY=your_rits_api_key_here

# Required: RITS API Base URL
RITS_API_BASE_URL=http://your-rits-server:4000

# ============================================
# OpenAI Configuration
# ============================================
# For OpenAI provider, set LLM_PROVIDER=openai above

OPENAI_API_KEY=your_openai_api_key_here

# ============================================
# Ollama Configuration
# ============================================
# For local Ollama, set LLM_PROVIDER=ollama above

OLLAMA_BASE_URL=http://localhost:11434

# ============================================
# Application Configuration
# ============================================

# API port (default: 8070)
API_PORT=8070

# Reports directory
REPORTS_DIR=./reports

# Enable debug mode
DEBUG=false

# ============================================
# Browser Configuration
# ============================================

# Run browser in headless mode
BROWSER_HEADLESS=true

# Page load timeout in milliseconds
PAGE_LOAD_TIMEOUT=30000
